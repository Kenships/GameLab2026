--- !u!114 &1020470267
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1020470265}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6bac1d07ecdad7c448833e4062102bf2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Scripts.Tutorial.TutorialComposer
  panels:
  - PanelText: Just when I thought I was out, you pull me back in...
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: Look what ya did, you little jerks! You just had to steal from a DVD
      store, didn't ya? We're stuck in this movie wasteland now.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: 'Testing testing...

      Try to move with the DIRECTIONAL-PAD.'
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355254}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutMovementListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: Test Successful.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: set_TimeToNextPanel
          m_Mode: 4
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 2
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: Don't worry, you're not alone here. The creatures in this wasteland
      will soon be flocking to you.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: You see, they love me. They <i>looove</i> to eat VHS tapes.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: 
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: set_TimeToNextPanel
          m_Mode: 4
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0.1
            m_StringArgument: 
            m_BoolArgument: 1
          m_CallState: 2
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 1
          m_CallState: 2
        - m_Target: {fileID: 11400000, guid: ea59c12e137cbf940b576ce2cfee1c24, type: 2}
          m_TargetAssemblyTypeName: Obvious.Soap.ScriptableEventGameObject, Obvious.Soap
          m_MethodName: Raise
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 2458656150517354803, guid: c7a1a6d130aea9947b7dda75f06722ef, type: 3}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 1
          m_CallState: 2
  - PanelText: Use the abandoned Modules to defend me, your Tape. Press A to pick-up
      or place your modules on a grass tile.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355253}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutPickupListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: You're gonna wanna protect me, by the way. I'm your only ticket outta
      here. I just need more... Time.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: Press B to rotate a Module. You can do this while it's on the ground.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355256}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutRotationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: Wow, you two might just have a chance to survive this.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: set_TimeToNextPanel
          m_Mode: 4
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 3
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: 'Fine, I''ll extend my powers to you. '
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: Lets Get some time into these hunks of junk. Hold B to REWIND a Module.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355259}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeControlListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: 'Ain''t that cool? We got it up and Going!  Next, we take over the
      world.

'
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: set_TimeToNextPanel
          m_Mode: 4
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 5
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: 'But that''s not all! The Time Bar above each module represents how
      much time it has left before breaking again. '
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: To really power it up we can fast forward the module by holding A.
      This will drain time faster but its worth it.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355260}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeControlListener,
            Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: "Incredible\u2026"
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: set_TimeToNextPanel
          m_Mode: 4
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 2
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 264355262}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutTimeListener, Assembly-CSharp
          m_MethodName: Invoke
          m_Mode: 0
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - PanelText: One last thing. There are Heavy Modules around the map. These are
      stationary, but they can shift the tide of the battle.
    OnPanel:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 264355255}
          m_TargetAssemblyTypeName: _Project.Scripts.Tutorial.TutConfirmationListener,
            Assembly-CSharp
          m_MethodName: Invoke
