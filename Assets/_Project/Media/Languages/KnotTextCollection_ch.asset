  m_Script: {fileID: 11500000, guid: ecacf7bdd7e77b2419e140cb5ded6aa5, type: 3}
  m_Name: KnotTextCollection_ch
  m_EditorClassIdentifier: Knot.Localization::Knot.Localization.Data.KnotTextCollection
  _items:
  - _key: Tut-line1
    _rawText: "\u54CE\u5440\u5440\u2026\u2026\u770B\u6765\u4F60\u4EEC\u8FD9\u5E2E\u5BB6\u4F19\u88AB\u5438\u8FDB\u8FD9\u4E2A\u7535\u5F71\u4E16\u754C\u4E86\u3002"
  - _key: Tut-line2
    _rawText: "\u6211\u5012\u662F\u80FD\u5E26\u4F60\u4EEC\u51FA\u53BB\uFF0C\u4E0D\u8FC7\u6761\u4EF6\u662F\u8981\u4FDD\u62A4\u6211\u3002\u770B\u5230\u53F3\u8FB9\u90A3\u76D8VHS\u5F55\u50CF\u5E26\u4E86\u5417\uFF1F\u90A3\u5C31\u662F\u6211\u3002"
  - _key: Tut-line3
    _rawText: "\u5148\u8BD5\u8BD5\u7528\u65B9\u5411\u952E\u79FB\u52A8\u3002"
  - _key: Tut-line4
    _rawText: "\u4E0D\u9519\u3002\u770B\u5230\u6211\u5934\u9876\u7684\u8840\u6761\u4E86\u5417\uFF1F\u4E0D\u592A\u5999\u3002\u5728\u6211\u65C1\u8FB9\u6309\u4F4F
      A \u952E\u5012\u5E26 = \u6CBB\u7597\u6211\u3002\u8C22\u4E86\u3002"
  - _key: Tut-line8
    _rawText: "\u5F88\u597D\u3002\u4E0D\u8FC7\u4F60\u53EF\u80FD\u6CE8\u610F\u5230\u4E86\u2026\u2026\u5B83\u73B0\u5728\u5565\u4E5F\u55B7\u4E0D\u51FA\u6765\u3002"
  - _key: Tut-line9
    _rawText: "\u56E0\u4E3A\u65F6\u95F4\u662F\u8FD9\u4E9B\u6A21\u5757\u7684\u71C3\u6599\u3002"
  - _key: Tut-line10
    _rawText: "\u8BD5\u8BD5\u6309\u4F4F A \u952E\u5012\u5E26\u4F60\u65C1\u8FB9\u90A3\u4E2A\u6A21\u5757\u3002"
  - _key: Tut-line11
    _rawText: "\u73B0\u5728\u6309\u4F4F B \u952E\u5FEB\u8FDB\u2014\u2014\u55B7\u706B\u66F4\u5FEB\uFF0C\u70E7\u5F97\u4E5F\u66F4\u5FEB\u3002"
  - _key: Tut-line12
    _rawText: "\u5982\u679C\u4F60\u81EA\u5DF1\u6B63\u62FF\u7740\u4E00\u4E2A\u6A21\u5757\uFF0C\u5C31\u4E0D\u80FD\u5BF9\u5B83\u8FDB\u884C\u65F6\u95F4\u64CD\u63A7\u4E86\u3002\u4F46\u53E6\u4E00\u4E2A\u73A9\u5BB6\u53EF\u4EE5\u2014\u2014\u4ED6\u4EEC\u6309\u4F4F
      A \u6216 B \u952E\uFF0C\u800C\u4F60\u5C31\u8D1F\u8D23\u62FF\u7740\u5B83\u3002"
  - _key: Tut-line13
    _rawText: "\u5176\u5B9E\u8FD8\u6709\u53E6\u4E00\u79CD\u6A21\u5757\uFF0C\u5148\u53BB\u62FF\u8FC7\u6765\uFF0C\u4E5F\u653E\u5728\u8349\u5730\u4E0A\u3002"
  - _key: Tut-line15
    _rawText: "\u64CD\u4F5C\u662F\u8FD9\u6837\u7684\uFF1A\u6309\u4F4F A \u952E\u628A\u5B83\u5012\u6EE1\uFF0C\u518D\u6309\u4F4F
      B \u952E\u8BA9\u5B83\u542F\u52A8\u3002\u5BF9\u7740\u90A3\u4E2A\u70B8\u836F\u7F50\u8BD5\u8BD5\u3002"
  - _key: Tut-line5
    _rawText: "\u602A\u7269\u5F88\u5FEB\u5C31\u8981\u6765\u627E\u6211\u4E86\u3002\u5149\u7528\u62F3\u5934\u53EF\u6CA1\u6CD5\u51FB\u9000\u4ED6\u4EEC\uFF0C\u6240\u4EE5\u6211\u7ED9\u4F60\u4EEC\u51C6\u5907\u4E86\u4E00\u4E2A\u706B\u7130\u55B7\u5C04\u5668\u3002"
  - _key: Tut-line6
    _rawText: "\u70B9\u51FB A \u952E\u62FF\u8D77\u6765\u3002\u518D\u70B9\u51FB A
      \u952E\u653E\u4E0B\uFF08\u53EA\u80FD\u5728\u8349\u5730\u4E0A\u653E\uFF09\u3002"
  - _key: Tut-line7
    _rawText: "\u4E0D\u9519\uFF01\u73B0\u5728\u8BD5\u8BD5\u70B9\u51FB B \u952E\u628A\u5B83\u8F6C\u4E2A\u65B9\u5411\u3002"
  - _key: Tut-line14
    _rawText: "\u5B83\u9876\u4E0A\u6709\u4E2A\u7535\u6C60\u56FE\u6807\uFF0C\u610F\u601D\u662F\u5B83\u9700\u8981\u704C\u6EE1\u65F6\u95F4\u624D\u80FD\u6FC0\u6D3B\u3002"
  - _key: Tut-line16
    _rawText: "<b> \u70B8\u54AF! </b>"
  - _key: Tut-line17
    _rawText: "\u5BF9\u4E86\uFF0C\u90A3\u8F86\u8F66\uFF1F\u8BD5\u8BD5\u5148\u5012\u5E26\uFF0C\u518D\u5FEB\u8FDB\u3002\uFF08\u6309\u4F4F
      A \u952E\uFF0C\u7136\u540E\u6309\u4F4F B \u952E\uFF09"
  - _key: Tut-line18
    _rawText: "\u54E6\u4E0D\uFF0C\u602A\u7269\u8981\u6765\u4E86\uFF0C\u4FDD\u62A4\u6211\uFF01"
  - _key: Tut-line19
    _rawText: "\u5E72\u5F97\u4E0D\u9519\u3002\u6B63\u5F0F\u5F00\u6253\u7684\u65F6\u5019\u6211\u4F1A\u518D\u6254\u4E00\u4E9B\u6A21\u5757\u7ED9\u4F60\u4EEC\u3002\u73B0\u5728\u53BB\u72E0\u72E0\u63CD\u4ED6\u4EEC\u5427\u3002\u6211\u5C31\u6307\u671B\u4F60\u4EEC\u4E86\u3002"
